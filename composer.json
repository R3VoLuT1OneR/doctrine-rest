{
    "name": "pz/doctrine-rest",
    "description": "Rest API library for Doctrine 2 ORM",
    "keywords": ["doctrine", "rest"],
    "license": "MIT",
    "type": "library",
    "minimum-stability": "stable",
    "require": {
        "php": "^8.0",
        "ext-json": "*",
        "doctrine/orm": "^2.5",
        "league/fractal": "^0.19.2",
        "psr/http-message": "^1.0",
        "fig/http-message-util": "dev-master",
        "psr/http-server-middleware": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Doctrine\\Rest\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Doctrine\\Rest\\Tests\\": "tests",
            "Doctrine\\Rest\\Tests\\Unit\\": "tests/unit",
            "Doctrine\\Rest\\Tests\\Entities\\": "tests/entities",
            "Doctrine\\Rest\\Tests\\Migrations\\": "tests/migrations"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^9.4",
        "mockery/mockery": "^1.4",
        "phpunit/php-code-coverage": "^9.2",
        "doctrine/migrations": "^1.2"
    },
    "config": {
        "github-protocols": ["https"]
    }
}
